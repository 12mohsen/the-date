<!doctype html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title data-i18n="pageTitle">عداد الأيام</title>
  <link rel="icon" type="image/png" href="سنبله.png?v=1" />
  <link rel="stylesheet" href="style.css" />
</head>
<body>
  <!-- شاشة تسجيل الدخول / الاشتراك -->
  <div id="auth-screen" class="auth-screen" hidden>
    <div class="auth-card">
      <div class="auth-top-controls">
        <button id="lang-toggle-auth" class="lang-toggle-btn" type="button" title="Switch language">EN</button>
      </div>
      <div class="auth-icon">👤</div>
      <h2 id="auth-title" data-i18n="authTitleLogin">تسجيل الدخول</h2>
      <p id="auth-subtitle" class="auth-subtitle" data-i18n="authSubtitleLogin">أدخل اسم المستخدم وكلمة المرور للمتابعة</p>

      <form id="auth-form" class="auth-form">
        <label for="auth-username" data-i18n="usernameLabel">اسم المستخدم</label>
        <input type="text" id="auth-username" autocomplete="username" required />

        <label for="auth-password" data-i18n="passwordLabel">كلمة المرور</label>
        <input type="password" id="auth-password" autocomplete="current-password" required />

        <div id="auth-hint-field" class="auth-hint-field" hidden>
          <label for="auth-hint" data-i18n="hintLabel">تلميح لكلمة المرور (يُعرض عند النسيان)</label>
          <input type="text" id="auth-hint" />
        </div>

        <button type="submit" id="auth-submit-btn" class="auth-submit-btn" data-i18n="loginBtn">دخول</button>

        <button type="button" id="auth-remind-btn" class="auth-remind-btn" hidden data-i18n="remindBtn">
          🔑 تذكير: اعرض التلميح
        </button>

        <p id="auth-hint-display" class="auth-hint-display" hidden></p>
        <p id="auth-error" class="auth-error" hidden></p>

        <div class="auth-toggle">
          <span id="auth-toggle-text" data-i18n="noAccount">ليس لديك حساب؟</span>
          <button type="button" id="auth-toggle-btn" class="auth-toggle-btn" data-i18n="goToSignup">إنشاء حساب جديد</button>
        </div>
      </form>
    </div>
  </div>

  <div class="app" id="main-app" hidden>
    <header class="app-header">
      <div class="header-controls">
        <button id="theme-toggle" class="theme-toggle-btn" data-i18n-aria="themeToggleAria" aria-label="تبديل ألوان الواجهة">
          ☾
        </button>
        <button id="lang-toggle" class="lang-toggle-btn" type="button" title="Switch language">EN</button>
      </div>

      <div id="user-bar" class="user-bar">
        <span class="user-icon">👤</span>
        <span class="user-welcome" data-i18n="welcome">مرحباً،</span>
        <span id="user-name" class="user-name"></span>
        <button id="logout-btn" class="logout-btn" type="button" data-i18n="logoutBtn" data-i18n-title="logoutBtn" title="تسجيل الخروج">
          تسجيل الخروج
        </button>
      </div>

      <h1 data-i18n="appTitle">عداد الأيام</h1>
      <p data-i18n="appSubtitle">احسب عدد الأيام بين تاريخين أو منذ / حتى تاريخ معين</p>
    </header>

    <main class="app-main">
      <section class="card">
        <div class="date-card-header">
          <span class="date-card-title" data-i18n="selectDate">اختر تاريخاً</span>
        </div>

        <div class="field-group single-date-group">
          <div class="date-input-wrapper" id="single-date-wrapper">
            <input type="date" id="single-date" />
          </div>
        </div>

        <div class="mode-toggle">
          <button id="mode-since" class="mode-btn active" data-i18n="modeSince">منذ التاريخ</button>
          <button id="mode-until" class="mode-btn" data-i18n="modeUntil">حتى التاريخ</button>
        </div>

        <div class="result-placeholder" id="result-placeholder" data-i18n="placeholderResult">
          يرجى اختيار تاريخ لعرض النتيجة
        </div>
      </section>

      <section class="result-card" id="result-card" hidden>
        <h2 data-i18n="resultTitle">النتيجة</h2>
        <p id="result-text"></p>
        <p id="result-equivalent" class="result-equivalent"></p>
        <p id="result-details" class="result-details"></p>
      </section>

      <section class="helper-text">
        <p data-i18n="reminderNote">تذكير: يتم الحساب بالاعتماد على الأيام الكاملة فقط بدون كسور الساعات.</p>
      </section>

      <section class="saved-section">
        <div class="saved-header">
          <h2 data-i18n="savedTitle">المدد المحفوظة</h2>
          <span id="saved-count" class="saved-count"></span>
          <div class="saved-controls">
            <label for="importance" data-i18n="importanceLabel">الأهمية</label>
            <select id="importance">
              <option value="normal" data-i18n="impNormal">عادي</option>
              <option value="important" data-i18n="impImportant">مهم ⭐</option>
              <option value="very-important" data-i18n="impVeryImportant">مهم جدًا ⭐⭐</option>
            </select>
            <button id="save-entry-btn" class="secondary-btn" data-i18n="saveEntryBtn">حفظ المدة الحالية في الجدول</button>
            <button id="trash-btn" class="secondary-btn" type="button" data-i18n="trashBtn">🗑 سلة المحذوفات</button>
          </div>
          <div class="saved-filters">
            <span class="saved-filters-label" data-i18n="filterByImportance">تصفية حسب الأهمية:</span>
            <button class="filter-btn active" data-importance="all" id="filter-all" data-i18n="filterAll">الكل</button>
            <button class="filter-btn" data-importance="normal" id="filter-normal" data-i18n="filterNormal">عادي</button>
            <button class="filter-btn" data-importance="important" id="filter-important" data-i18n="filterImportant">مهم</button>
            <button class="filter-btn" data-importance="very-important" id="filter-very-important" data-i18n="filterVeryImportant">مهم جدًا</button>
          </div>
        </div>

        <div class="saved-table-wrapper">
          <div id="saved-list" class="saved-list">
          </div>
        </div>
      </section>
    </main>
    <footer class="app-footer">
      <span data-i18n="copyright">حقوق الملكية mohsen</span>
    </footer>
  </div>

  <div id="trash-modal" class="trash-modal" hidden>
    <div class="trash-modal-content">
      <div class="trash-modal-header">
        <h2 data-i18n="trashTitle">🗑 سلة المحذوفات</h2>
        <button id="trash-close-btn" class="trash-close-btn" data-i18n-aria="closeAria" aria-label="إغلاق">✕</button>
      </div>
      <p class="trash-note" data-i18n="trashNote">
        يتم الحذف النهائي تلقائياً بعد مرور 30 يوماً من الحذف.
      </p>
      <div id="trash-list" class="trash-list"></div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
  <script src="i18n.js"></script>
  <script src="supabase.js"></script>
  <script src="main.js"></script>
</body>
</html>
